# Agrobot environment variables

# Database (matches docker-compose postgres service)
AGROBOT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agrobot
AGROBOT_REPLICA_DATABASE_URL=

# JWT auth
AGROBOT_JWT_SECRET_KEY=dev-secret-change-in-production
AGROBOT_JWT_ALGORITHM=HS256
AGROBOT_JWT_EXPIRATION_MINUTES=60

# AWS / LocalStack (matches docker-compose localstack service)
AGROBOT_AWS_REGION=us-east-1
AGROBOT_AWS_ENDPOINT_URL=http://localhost:4566
AGROBOT_KINESIS_STREAM_NAME=weather-events
AGROBOT_SQS_QUEUE_URL=http://localhost:4566/000000000000/agrobot-alerts
AGROBOT_SQS_DLQ_URL=http://localhost:4566/000000000000/agrobot-alerts-dlq

# Kapso notification provider (leave empty for local dev, notifications will fail gracefully)
AGROBOT_KAPSO_API_URL=
AGROBOT_KAPSO_API_KEY=

# Rate limiting
AGROBOT_RATE_LIMIT_PER_MINUTE=60

# Environment
AGROBOT_ENVIRONMENT=development
